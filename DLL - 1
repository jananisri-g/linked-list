#include <bits/stdc++.h>
using namespace std;

class Node{
public:
    int data;
    Node* next;
    Node* prev;

    Node(int d1){
        data = d1;
        next = nullptr;
        prev = nullptr;
    }

    Node(int d1, Node* n1, Node* p1){
        data = d1;
        next = n1;
        prev = p1;
    }
};

Node* insertAtHead(Node* head, int x){
    Node* y = new Node(x);
    y->next = head;
    head = y;
    return head;
}

Node* deleteAtHead(Node* head){
    Node* y = head;
    head = head->next;
    delete y;
    return head;
}

Node* reverseDLL(Node* head) {

    if (head == nullptr || head->next == nullptr) return head;

    Node* curr = head;

    while (curr != nullptr) {
     
        Node* temp = curr->next;
        curr->next = curr->prev;
        curr->prev = temp;

        head = curr;          
        curr = temp;          
    }

    return head;
}

void display(Node* head){
    
    while(head != NULL){
        cout<<head->data<<" ";
        head = head->next;
    }
    cout<<"\n";
    
}

int main(){

    Node* head = new Node(2);

    Node* second = new Node(3);
    second->prev = head;
    head->next = second;

    Node* third = new Node(4);
    third->prev = second;
    second->next = third;

    Node* fourth = new Node(5);
    fourth->prev = third;
    third->next = fourth;
    
    head = insertAtHead(head, 0);
    head = insertAtHead(head, 9);
    
    cout<<"After insertion: ";
    display(head);
    
    head = deleteAtHead(head);
    
    cout<<"After deletion: ";
    display(head);
    
    head = reverseDLL(head);
    
    cout<<"After reversing: ";
    display(head);

    return 0;
}
