#include<bits/stdc++.h>
using namespace std;

class Node{
public:
    int data;
    Node* next;

    Node(int d1, Node* n1){
        data = d1;
        next = n1;
    }

    Node(int d1){
        data = d1;
        next = nullptr;
    }
};

Node* insertatHead(Node* head, int d){
    Node* x = new Node(d);
    x->next = head;
    head = x;
    return head;
}

Node* deleteatHead(Node* head){
    Node* x = head;
    head = head->next;
    delete x;
    return head;
}

bool searchNode(Node* head, int x){
    Node* temp = head;
    while(temp != NULL){
        if(temp->data == x) return true;
        temp = temp->next;
    }
    return false;
}
int main() {
    
    Node* head = new Node(2);
    head->next = new Node(3);
    head->next->next = new Node(4);
    head->next->next->next = new Node(5);
    head->next->next->next->next = new Node(6);
    
    head = insertatHead(head, 1);
    Node* temp = head;
    int count = 0;
    while(temp != nullptr){
        cout << temp->data << " ";
        count++;
        temp = temp->next;
    }
    cout<<"\n"<<count<<"\n";
    
     head = deleteatHead(head);
     Node* newtemp = head;
    while(newtemp != nullptr){
        cout << newtemp->data << " ";
        newtemp = newtemp->next;
    }
    
    cout<<"\n"<<(searchNode(head, 1));

    return 0;
}
